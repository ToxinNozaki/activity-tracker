# ── Roblox ──────────────────────────────────────────────────────────────────
# Your .ROBLOSECURITY cookie (the value only, no warning prefix)
ROBLOX_COOKIE=

# ── Discord Bot ──────────────────────────────────────────────────────────────
# From discord.com/developers/applications → your bot → Bot → Token
DISCORD_BOT_TOKEN=

# Right-click the channel you want posts in → Copy Channel ID
# (Developer Mode must be on: User Settings → Advanced → Developer Mode)
DISCORD_CHANNEL_ID=

# ── Check interval ───────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=5
